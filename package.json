{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "Discord bot built with discord.js v14 and TypeScript",
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon",
    "start": "ts-node -r tsconfig-paths/register src/index.ts",
    "deploy": "ts-node -r tsconfig-paths/register src/deploy-commands.ts",
    "build": "tsc"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.15.2",
    "discord.js": "^14.26.3",
    "dotenv": "^16.6.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
