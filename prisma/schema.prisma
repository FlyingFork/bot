generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TranslationGroup {
  id       String               @id @default(cuid())
  guildId  String
  name     String
  channels TranslationChannel[]

  @@unique([guildId, name])
}

model TranslationChannel {
  id           String           @id @default(cuid())
  channelId    String           @unique
  language     String
  webhookId    String?
  webhookToken String?
  group        TranslationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String
}

model TranslationStat {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  date      DateTime
  count     Int      @default(0)

  @@unique([guildId, channelId, date])
}
